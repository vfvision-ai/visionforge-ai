# ─────────────────────────────────────────────────────────────
# VisionForge — Environment Configuration Template
#
# Copy this file to .env:
#   cp .env.example .env
#
# NEVER commit .env to version control!
# ─────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────
APP_NAME=VisionForge
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-run-openssl-rand-hex-32

# ── API Authentication ────────────────────────────────────────
# Leave blank to disable auth in dev.
# Set a strong value in production: openssl rand -hex 32
API_KEY=

# ── CORS ──────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:8501,http://localhost:3000

# ── Database ──────────────────────────────────────────────────
# SQLite (default — no extra service needed):
DATABASE_URL=sqlite:///./ml_platform.db

# PostgreSQL (uncomment for production):
# DATABASE_URL=postgresql://mluser:changeme@postgres:5432/ml_platform
POSTGRES_DB=ml_platform
POSTGRES_USER=mluser
POSTGRES_PASSWORD=changeme-in-production

# ── Celery / Redis ────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Streamlit ─────────────────────────────────────────────────
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_SERVER_ENABLE_CORS=false
STREAMLIT_SERVER_ENABLE_XSRF_PROTECTION=true
STREAMLIT_SERVER_MAX_UPLOAD_SIZE=2048

# ── Storage paths ─────────────────────────────────────────────
DATA_DIR=./data
UPLOADS_DIR=./uploads
EXPERIMENTS_DIR=./experiments
LOGS_DIR=./logs
MAX_FILE_SIZE_MB=2048

# ── ML / Training ─────────────────────────────────────────────
DEFAULT_FRAMEWORK=pytorch
MAX_EPOCHS=200
DEFAULT_BATCH_SIZE=32

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/app.log

# ── Monitoring ────────────────────────────────────────────────
PROMETHEUS_PORT=9090
METRICS_ENABLED=true

# ── External integrations (all optional) ─────────────────────
# HF_TOKEN=                        # Hugging Face private datasets
# WANDB_API_KEY=                   # Weights & Biases
# WANDB_PROJECT=cv-training

# ── AWS (for CI/CD ECR push and EC2 deployment) ───────────────
# AWS_REGION=us-east-1
# ECR_REGISTRY=123456789012.dkr.ecr.us-east-1.amazonaws.com
# ECR_REPO=cv-training-pipeline
# AWS_ROLE_ARN=arn:aws:iam::123456789012:role/GitHubActionsRole
